# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env

# pnpm-workspace.yaml IS committed here on purpose: it pins web as its own
# single-package workspace root, isolating it from the repo-root workspace
# (game + agent) so web's Vercel build and lockfile stay independent.
pnpm-lock.yaml
# only pnpm-lock.yaml should be committed; npm install should not be run in this package
package-lock.json
